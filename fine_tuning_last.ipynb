ion |   Test Spearman Correlation |\n","|:-----------|---------------------------------:|----------------------------------:|---------------------------:|----------------------------:|\n","| Baseline   |                         0.180328 |                          0.183176 |                   0.102748 |                   0.0972185 |\n","| Fine-tuned |                         0.365193 |                          0.390976 |                   0.430537 |                   0.445952  |\n"]}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import pandas as pd\n","\n","# 1. Extract the logs for loss values\n","history_df = pd.DataFrame(trainer.state.log_history)\n","\n","# 2. Filter data\n","# Training/Val Loss are available in the log history\n","loss_df = history_df.dropna(subset=['loss'])\n","eval_loss_df = history_df.dropna(subset=['eval_loss'])\n","\n","# Evaluation Metrics (Pearson/Spearman) are saved to a CSV by the evaluator\n","# eval_metrics_csv_path is already defined: './eval_results/similarity_evaluation_val_results.csv'\n","# eval_metrics_df is already loaded: pd.read_csv(eval_metrics_csv_path)\n","\n","# Prepare data for plotting\n","# We need to align the number of correlation points with the number of evaluation epochs from eval_loss_df.\n","# From the kernel state, eval_metrics_df.iloc[2:] has 3 rows, while eval_loss_df has 4 evaluation epochs (1, 2, 3, 4).\n","# To avoid index mismatch, we'll take the minimum number of available evaluation points.\n","num_eval_points = min(len(eval_loss_df), len(eval_metrics_df.iloc[2:]))\n","\n","# Get epochs for plotting correlations - use epochs from eval_loss_df for alignment\n","epochs_for_corr_plot = eval_loss_df['epoch'].iloc[:num_eval_points]\n","pearson_scores = eval_metrics_df['cosine_pearson'].iloc[2:2+num_eval_points]\n","spearman_scores = eval_metrics_df['cosine_spearman'].iloc[2:2+num_eval_points]\n","\n","# 3. Create a dual-plot layout\n","fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 5))\n","\n","# Plot 1: Training and Validation Loss\n","ax1.plot(loss_df['epoch'], loss_df['loss'], label='Training Loss', color='blue', marker='o', alpha=0.5)\n","ax1.plot(eval_loss_df['epoch'], eval_loss_df['eval_loss'], label='Validation Loss', color='orange', marker='s', linestyle='--')\n","ax1.set_title('Training vs Validation Loss')\n","ax1.set_xlabel('Epoch')\n","ax1.set_ylabel('Loss')\n","ax1.legend()\n","ax1.grid(True, linestyle=':', alpha=0.6)\n","\n","# Plot 2: Evaluation Metrics (Pearson & Spearman)\n","# Use the aligned epochs for the x-axis\n","ax2.plot(epochs_for_corr_plot, pearson_scores, label='Pearson Correlation', color='green', marker='o')\n","ax2.plot(epochs_for_corr_plot, spearman_scores, label='Spearman Correlation', color='red', marker='x', linestyle='--')\n","ax2.set_title('Evaluation Metrics (Cosine Similarity)')\n","ax2.set_xlabel('Epoch')\n","ax2.set_ylabel('Correlation Score')\n","ax2.legend()\n","ax2.grid(True, linestyle=':', alpha=0.6)\n","\n","plt.tight_layout()\n","plt.show()\n","\n","if len(eval_loss_df) != len(eval_metrics_df.iloc[2:]):\n","    print(f\"Note: There is a mismatch in the number of logged evaluation epochs ({len(eval_loss_df)}) \"\n","          f\"and the number of correlation data points available from the CSV ({len(eval_metrics_df.iloc[2:])}). \"\n","          \"The correlation plot therefore only displays the first few available points.\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":220},"id":"8kM_Wncq6klz","executionInfo":{"status":"ok","timestamp":1782494142469,"user_tz":-345,"elapsed":523,"user":{"displayName":"Prabin Rimal","userId":"08922284831399208565"}},"outputId":"83c3274f-0210-4458-b31b-084aa3f70eba"},"execution_count":128,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x500 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Note: There is a mismatch in the number of logged evaluation epochs (4) and the number of correlation data points available from the CSV (3). The correlation plot therefore only displays the first few available points.\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":193},"id":"8cf0715a","executionInfo":{"status":"ok","timestamp":1782494262209,"user_tz":-345,"elapsed":428,"user":{"displayName":"Prabin Rimal","userId":"08922284831399208565"}},"outputId":"439b6771-93f8-40bd-886b-4012e853b823"},"source":["import matplotlib.pyplot as plt\n","import seaborn as sns\n","\n","# Prepare data for plotting\n","plot_df = comparison_df.melt(id_vars='Model',\n","                             value_vars=['Validation Pearson Correlation', 'Validation Spearman Correlation',\n","                                         'Test Pearson Correlation', 'Test Spearman Correlation'],\n","                             var_name='Metric',\n","                             value_name='Correlation Score')\n","\n","# Create a figure with two subplots\n","fig, axes = plt.subplots(1, 2, figsize=(18, 6), sharey=True)\n","\n","# Plot for Pearson Correlations\n","pearson_df = plot_df[plot_df['Metric'].str.contains('Pearson')]\n","sns.barplot(x='Metric', y='Correlation Score', hue='Model', data=pearson_df, palette='viridis', ax=axes[0])\n","axes[0].set_title('Pearson Correlation Comparison')\n","axes[0].set_xlabel('Dataset and Metric Type')\n","axes[0].set_ylabel('Correlation Score')\n","axes[0].tick_params(axis='x', rotation=15)\n","axes[0].grid(axis='y', linestyle='--', alpha=0.7)\n","axes[0].set_ylim(0, 0.5) # Set consistent y-axis limit\n","\n","\n","# Plot for Spearman Correlations\n","spearman_df = plot_df[plot_df['Metric'].str.contains('Spearman')]\n","sns.barplot(x='Metric', y='Correlation Score', hue='Model', data=spearman_df, palette='viridis', ax=axes[1])\n","axes[1].set_title('Spearman Correlation Comparison')\n","axes[1].set_xlabel('Dataset and Metric Type')\n","axes[1].set_ylabel('Correlation Score')\n","axes[1].tick_params(axis='x', rotation=15)\n","axes[1].grid(axis='y', linestyle='--', alpha=0.7)\n","axes[1].set_ylim(0, 0.5) # Set consistent y-axis limit\n","\n","\n","plt.tight_layout()\n","plt.show()"],"execution_count":132,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["print('--- Actual Vector Shift (Improvement) ---')\n","\n","# Calculate the difference for each metric\n","# Assuming comparison_df has 'Baseline' as the first row and 'Fine-tuned' as the second\n","shift_df = pd.DataFrame({\n","    'Metric': ['Validation Pearson Correlation', 'Validation Spearman Correlation',\n","               'Test Pearson Correlation', 'Test Spearman Correlation'],\n","    'Shift (Fine-tuned - Baseline)': [\n","        comparison_df.loc[1, 'Validation Pearson Correlation'] - comparison_df.loc[0, 'Validation Pearson Correlation'],\n","        comparison_df.loc[1, 'Validation Spearman Correlation'] - comparison_df.loc[0, 'Validation Spearman Correlation'],\n","        comparison_df.loc[1, 'Test Pearson Correlation'] - comparison_df.loc[0, 'Test Pearson Correlation'],\n","        comparison_df.loc[1, 'Test Spearman Correlation'] - comparison_df.loc[0, 'Test Spearman Correlation']\n","    ]\n","})\n","\n","print(shift_df.to_markdown(index=False))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"9VKGakBj8RdV","executionInfo":{"status":"ok","timestamp":1782494375617,"user_tz":-345,"elapsed":60,"user":{"displayName":"Prabin Rimal","userId":"08922284831399208565"}},"outputId":"56e6f2bc-d119-4294-bdfe-543c99f248dc"},"execution_count":133,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Actual Vector Shift (Improvement) ---\n","| Metric                          |   Shift (Fine-tuned - Baseline) |\n","|:--------------------------------|--------------------------------:|\n","| Validation Pearson Correlation  |                        0.184865 |\n","| Valid