b(r'http\\S+|www\\.\\S+', ' ', text)         # remove URLs\n","    text = re.sub(r'\\S+@\\S+\\.\\S+', ' ', text)            # remove email addresses\n","    text = re.sub(r'[^\\x00-\\x7F]+', ' ', text)              # remove unidentifiable / non-ASCII characters\n","    text = re.sub(r'[^\\w\\s]', ' ', text)                   # remove punctuation and special characters\n","    text = re.sub(r'\\b\\w*\\d\\w*\\b', ' ', text)          # remove noisy tokens with digits\n","    text = re.sub(r'\\s+', ' ', text).strip()               # collapse whitespace\n","    return text\n"],"metadata":{"id":"m7dlCVwU_tZF","executionInfo":{"status":"ok","timestamp":1782481770787,"user_tz":-345,"elapsed":14,"user":{"displayName":"Prabin Rimal","userId":"08922284831399208565"}}},"execution_count":35,"outputs":[]},{"cell_type":"code","source":["print(\"Loading datasets...\")\n","\n","train_df = pd.read_csv(\"/content/drive/MyDrive/Colab Notebooks/fine_tuning_bert/train_clean.csv\")\n","test_raw  = pd.read_csv(\"/content/drive/MyDrive/Colab Notebooks/fine_tuning_bert/test_clean.csv\")\n","\n","train_df = train_df.dropna(subset=['label']).reset_index(drop=True)\n","test_raw  = test_raw.dropna(subset=['label'])          # keep original index for split\n","\n","# FIX: sample → drop using ORIGINAL index → THEN reset both\n","val_df  = test_raw.sample(frac=0.5, random_state=42)  # keeps original index\n","test_df = test_raw.drop(val_df.index)                  # correct complement\n","\n","val_df  = val_df.reset_index(drop=True)\n","test_df = test_df.reset_index(drop=True)\n","\n","label_mapping = {'Good Fit': 1.0, 'Potential Fit': 0.5, 'No Fit': 0.0}\n","\n","for name, df in [('Train', train_df), ('Val', val_df), ('Test', test_df)]:\n","    dist = df['label'].value_counts().to_dict()\n","    print(f'{name:<6}: {len(df):>5} rows  {dist}')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"s8Gw_273MuHJ","executionInfo":{"status":"ok","timestamp":1782481918918,"user_tz":-345,"elaps